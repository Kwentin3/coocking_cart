APP_ENV=demo
APP_NAME=coocking-cart
APP_BASE_URL=https://coocking-cart.speechbattle.com
PUBLIC_DOMAIN=coocking-cart.speechbattle.com

DEMO_MODE=true

SQLITE_DB_PATH=./data/demo.sqlite

CONTEXT_MANIFEST_PATH=./docs/mvp/context/context_manifest.yml
CONTEXT_LAYERS_DIR=./docs/mvp/context

LLM_PROVIDER=gemini
LLM_MODEL=gemini-flash-latest
LLM_API_KEY=
LLM_BASE_URL=
LLM_TIMEOUT_SECONDS=60

STT_ENABLED=true
STT_PROVIDER=gemini
STT_MODEL=
STT_API_KEY=
STT_BASE_URL=
STT_TIMEOUT_SECONDS=90
STT_MAX_AUDIO_SECONDS=180
STT_COUNTDOWN_SECONDS=15
STT_MAX_AUDIO_BYTES=12000000

LIVE_VOICE_ENABLED=true
LIVE_VOICE_PROVIDER=gemini
LIVE_VOICE_MODEL=gemini-3.1-flash-live-preview
LIVE_VOICE_API_KEY=
LIVE_VOICE_BASE_URL=
LIVE_VOICE_TIMEOUT_SECONDS=10
LIVE_VOICE_TOKEN_TTL_SECONDS=1800
LIVE_VOICE_NEW_SESSION_SECONDS=60
LIVE_VOICE_INPUT_SAMPLE_RATE=16000
LIVE_VOICE_RESPONSE_MODALITY=TEXT

ENABLE_CONTEXT_INSPECTOR=true
ENABLE_LLM_TRACE=true

BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_PASSWORD_HASH=
AUTH_SESSION_SECRET=

DEPLOY_HOST=91.132.48.224
DEPLOY_USER=root
TRAEFIK_NETWORK_NAME=<TRAEFIK_NETWORK_NAME>
TRAEFIK_ENTRYPOINT=<TRAEFIK_ENTRYPOINT>
TRAEFIK_CERTRESOLVER=<TRAEFIK_CERTRESOLVER>
