APP_ENV=demo
APP_NAME=coocking-cart
APP_BASE_URL=https://coocking-cart.speechbattle.com
PUBLIC_DOMAIN=coocking-cart.speechbattle.com

DEMO_MODE=true

SQLITE_DB_PATH=./data/demo.sqlite

CONTEXT_MANIFEST_PATH=./docs/mvp/context/context_manifest.yml
CONTEXT_LAYERS_DIR=./docs/mvp/context

LLM_PROVIDER=gemini
LLM_MODEL=gemini-flash-latest
LLM_API_KEY=
LLM_BASE_URL=
LLM_TIMEOUT_SECONDS=60

ENABLE_CONTEXT_INSPECTOR=true
ENABLE_LLM_TRACE=true

BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_PASSWORD_HASH=
AUTH_SESSION_SECRET=

DEPLOY_HOST=91.132.48.224
DEPLOY_USER=root
TRAEFIK_NETWORK_NAME=<TRAEFIK_NETWORK_NAME>
TRAEFIK_ENTRYPOINT=<TRAEFIK_ENTRYPOINT>
TRAEFIK_CERTRESOLVER=<TRAEFIK_CERTRESOLVER>
