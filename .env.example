APP_ENV=demo
APP_NAME=coocking-cart
APP_BASE_URL=https://coocking-cart.speechbattle.com
# Empty keeps legacy root mode. Use /mvp when the MVP is routed behind the landing on one domain.
APP_BASE_PATH=
PUBLIC_DOMAIN=coocking-cart.speechbattle.com

DEMO_MODE=true

SQLITE_DB_PATH=./data/demo.sqlite

CONTEXT_MANIFEST_PATH=./docs/mvp/context/context_manifest.yml
CONTEXT_LAYERS_DIR=./docs/mvp/context

LLM_PROVIDER=gemini
LLM_MODEL=gemini-flash-latest
LLM_API_KEY=
LLM_BASE_URL=
LLM_TIMEOUT_SECONDS=60

STT_ENABLED=true
STT_PROVIDER=gemini
STT_MODEL=
STT_API_KEY=
STT_BASE_URL=
STT_TIMEOUT_SECONDS=90
STT_MAX_AUDIO_SECONDS=180
STT_COUNTDOWN_SECONDS=15
STT_MAX_AUDIO_BYTES=12000000

# Shared transcription policy for batch STT and Gemini Live input transcription.
# For Gemini Live this is a prompt-level preference, not an API languageCode.
VOICE_TRANSCRIPTION_LANGUAGE=русский
VOICE_TRANSCRIPTION_SCRIPT=кириллица
VOICE_TRANSCRIPTION_LATIN_ALLOWLIST=iiko, r_keeper, StoreHouse, HACCP
VOICE_TRANSCRIPTION_DOMAIN_TERMS=ТК, ТТК, брутто, нетто, выход, БЖУ, ХАССП, СанПиН, 1С
VOICE_TRANSCRIPTION_UNCLEAR_MARKER=[неразборчиво]
VOICE_TRANSCRIPTION_EXTRA_INSTRUCTION=
VOICE_TRANSCRIPTION_PROMPT_OVERRIDE=

LIVE_VOICE_ENABLED=true
LIVE_VOICE_PROVIDER=gemini
LIVE_VOICE_MODEL=gemini-3.1-flash-live-preview
LIVE_VOICE_API_KEY=
LIVE_VOICE_BASE_URL=
LIVE_VOICE_TIMEOUT_SECONDS=10
LIVE_VOICE_TOKEN_TTL_SECONDS=1800
LIVE_VOICE_NEW_SESSION_SECONDS=60
LIVE_VOICE_INPUT_SAMPLE_RATE=16000
LIVE_VOICE_RESPONSE_MODALITY=AUDIO

# Live Voice SOCKS5 egress, backend only. Use server_proxy to enable.
LIVE_VOICE_TRANSPORT=server_proxy
LIVE_VOICE_SOCKS5_HOST=
LIVE_VOICE_SOCKS5_PORT=1080
LIVE_VOICE_SOCKS5_USERNAME=
LIVE_VOICE_SOCKS5_PASSWORD=

# Backend-only generated asset candidates. Real provider calls stay disabled
# unless ASSET_GENERATION_ENABLED=true is set explicitly.
ASSET_GENERATION_ENABLED=false
ASSET_PROVIDER=mock
ASSET_MODEL=
ASSET_GEMINI_API_KEY=
ASSET_OPENAI_API_KEY=
ASSET_OPENAI_BASE_URL=https://api.openai.com
ASSET_BASE_URL=
ASSET_TIMEOUT_SECONDS=120
ASSET_STORAGE_ROOT=./data/generated-assets
ASSET_MAX_CANDIDATES_PER_RUN=2

ENABLE_CONTEXT_INSPECTOR=true
ENABLE_LLM_TRACE=true

BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_PASSWORD_HASH=
AUTH_SESSION_SECRET=
# auto: Secure on HTTPS/proxy requests, off for local http://127.0.0.1.
SESSION_COOKIE_SECURE=auto

DEPLOY_HOST=91.132.48.224
DEPLOY_USER=root
TRAEFIK_NETWORK_NAME=<TRAEFIK_NETWORK_NAME>
TRAEFIK_ENTRYPOINT=<TRAEFIK_ENTRYPOINT>
TRAEFIK_CERTRESOLVER=<TRAEFIK_CERTRESOLVER>
